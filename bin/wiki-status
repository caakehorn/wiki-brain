#!/usr/bin/env bash
# Snapshot of wiki health: page counts, status distribution, queue depth.
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
echo "pages:   $(find "$ROOT/wiki" -name '*.md' | wc -l | tr -d ' ')"
echo "raw:     $(find "$ROOT/raw" -type f | wc -l | tr -d ' ')"
echo "inbox:   $(find "$ROOT/inbox" -type f | wc -l | tr -d ' ') files awaiting ingest"
echo ""
echo "status distribution:"
grep -rh "^status:" "$ROOT/wiki" --include="*.md" | sort | uniq -c | sort -rn
echo ""
echo "recent ops:"
grep "^## \[" "$ROOT/log.md" | tail -5
