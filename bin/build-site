JS = """\
(function(){
  var box=document.getElementById('q');
  if(!box)return;
  var data=null;
  fetch('search.json').then(function(r){return r.json()}).then(function(j){data=j}).catch(function(){});
  box.addEventListener('input',function(){
    var q=box.value.toLowerCase().trim();
    var host=document.getElementById('search-results');
    if(!host)return;
    if(!q||!data){host.innerHTML='';return;}
    var hits=data.filter(function(d){
      return d.title.toLowerCase().indexOf(q)>=0 || d.domain.indexOf(q)>=0 || (d.snippet||'').toLowerCase().indexOf(q)>=0;
    }).slice(0,25);
    host.innerHTML=hits.map(function(d){
      return '<a href="'+d.url+'"><strong>'+d.title+'</strong> <span style="color:#54595d">('+d.domain+')</span><br><span style="font-size:.82rem;color:#54595d">'+ (d.snippet||'') +'</span></a>';
    }).join('') || '<p style="color:#54595d">No matches.</p>';
  });
})();
"""


def render_page(meta: dict, body_html: str, page_rel: str, title: str,
                 toc: list[tuple[int, str, str]], known: set, out_root: Path,
                 base_url: str, navbox_html: str = "", infobox_html: str = "",
                 img_url: str = "", article_img: str = "") -> str:
    domain = meta.get("domain") or (Path(page_rel).parts[1] if len(Path(page_rel).parts) > 1 else "")
    badges = []
    if meta.get("status"):
        badges.append(f'<span class="badge status-{meta["status"]}">{esc_html(meta["status"])}</span>')
    if meta.get("importance"):
        badges.append(f'<span class="badge imp-{meta["importance"]}">{esc_html(meta["importance"])}</span>')
    if meta.get("page_type"):
        badges.append(f'<span class="badge">{esc_html(meta["page_type"])}</span>')
    if meta.get("date_modified"):
        badges.append(f'<span class="badge">updated {esc_html(meta["date_modified"])}</span>')
    badge_html = f'<div class="badges">{"".join(badges)}</div>' if badges else ""

    crumb_parts = [f'<a href="{relative_url(page_rel, "index.html")}">Wiki</a>']
    if domain:
        crumb_parts.append(
            f'<a href="{relative_url(page_rel, "wiki/" + domain + "/index.html")}">{esc_html(DOMAIN_TITLES.get(domain, domain))}</a>'
        )
    crumb_parts.append(f"<span>{esc_html(title)}</span>")
    crumbs = '<div class="crumbs">' + " &rsaquo; ".join(crumb_parts) + "</div>"

    toc_html = ""
    if toc:
        items = ""
        for lvl, txt, anchor in toc:
            cls = "sub" if lvl >= 3 else ""
            items += f'<a class="{cls}" href="#{anchor}">{esc_html(txt)}</a>'
        toc_html = f'<div class="toc"><h4>On this page</h4>{items}</div>'

    sidebar = render_sidebar(page_rel)

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{esc_html(title)} — wiki-brain</title>
<link rel="stylesheet" href="{relative_url(page_rel, 'assets/style.css')}">
</head>
<body>
<header class="site">
  <div class="brand">wiki-brain<small>compiled second brain</small></div>
  <input id="q" type="search" placeholder="Search the wiki… (titles, domains, snippets)" autocomplete="off">
</header>
<div class="layout">
{sidebar}
<main class="content">
{crumbs}
{toc_html}
{badge_html}
{infobox_html}
<div class="article-figure">{article_img}</div>
{body_html}
{navbox_html}
<div class="meta-note">This is the compiled wiki (<code>wiki/</code>), served as static HTML.
Prefer it over the source archive. Source of truth: GitHub <code>main</code>.
See <a href="{relative_url(page_rel, 'AGENT_ACCESS.md')}">AGENT_ACCESS.md</a> for the machine feed.</div>
</main>
</div>
<div id="search-results" style="max-width:1200px;margin:0 auto;padding:0 2rem 3rem"></div>
<script src="{relative_url(page_rel, 'assets/app.js')}"></script>
</body>
</html>"""


def render_sidebar(page_rel: str) -> str:
    items = "".join(
        f'<li><a href="{relative_url(page_rel, "wiki/" + d + "/index.html")}">'
        f'{esc_html(DOMAIN_TITLES.get(d, d))}</a></li>'
        for d in DOMAINS
    )
    return f"""<nav class="sidebar">
<h2>Domains</h2><ul>{items}</ul>
<h2>Top</h2><ul>
<li><a href="{relative_url(page_rel, 'index.html')}">Home</a></li>
<li><a href="{relative_url(page_rel, 'llms.txt')}">llms.txt</a></li>
<li><a href="{relative_url(page_rel, 'agent/manifest.json')}">manifest.json</a></li>
</ul></nav>"""


# --------------------------------------------------------------------------
# images + infobox + navbox (Wikipedia-style chrome)
# --------------------------------------------------------------------------
# default illustration per domain; fallbacks by page_type
DOMAIN_IMG = {
    "self": "self", "timeline": "timeline", "people": "people", "mind": "mind",
    "work": "work", "interests": "interests", "health": "health",
    "places": "places", "legal": "legal",
}
TYPE_IMG = {
    "event": "event", "period": "period", "summary": "generic",
    "entity": "people", "concept": "generic", "profile": "mind",
    "synthesis": "generic", "report": "generic", "chat": "generic",
    "note": "generic", "index": "generic",
}


def image_for(page_rel: str, meta: dict, known_imgs: set) -> str:
    """Return a relative url (from page) to an illustration for this page.

    Priority: explicit frontmatter 'image:' -> domain default -> type default
    -> generic. We resolve against assets/img/<name>.svg.
    """
    name = None
    if meta.get("image"):
        cand = meta["image"].strip().lstrip("/")
        # accept either 'self' (=> assets/img/self.svg) or a full path
        stem = cand.rsplit("/", 1)[-1].rsplit(".", 1)[0]
        name = stem
    if not name:
        name = DOMAIN_IMG.get(meta.get("domain", "")) or TYPE_IMG.get(
            meta.get("page_type", "")) or "generic"
    # verify the asset exists; fall back to generic
    if f"assets/img/{name}.svg" not in known_imgs:
        name = "generic"
    return relative_url(page_rel, f"assets/img/{name}.svg")


def build_navbox(domain: str, page_rel: str, siblings: dict, title_map: dict) -> str:
    """Purple Wikipedia-style navbox footer listing sibling pages in a domain."""
    if not domain or domain not in siblings:
        return ""
    entries = siblings.get(domain, [])
    # dedupe, drop self
    seen = set()
    items = []
    for rel_html, title in entries:
        if rel_html == page_rel:
            continue
        if rel_html in seen:
            continue
        seen.add(rel_html)
        url = relative_url(page_rel, rel_html)
        items.append(f'<li><a href="{esc_attr(url)}">{esc_html(title)}</a></li>')
    if not items:
        return ""
    title = DOMAIN_TITLES.get(domain, domain)
    return (
        f'<div class="navbox" role="navigation" aria-label="{esc_attr(title)} navigation">\n'
        f'<div class="navbox-title">{esc_html(title)} articles</div>\n'
        f'<ul class="navbox-list">{"".join(items)}</ul>\n'
        f'</div>'
    )


def build_infobox(meta: dict, page_rel: str, img_url: str, wikilink_fn) -> str:
    """Top-right Wikipedia-style infobox. Renders only if an 'infobox' map
    is present in frontmatter. `image` is auto-supplied; the map supplies
    labelled rows (label: value, value may contain [[wikilinks]])."""
    fb = meta.get("infobox")
    if not isinstance(fb, dict) or not fb:
        return ""
    head = fb.get("name") or meta.get("title") or ""
    rows = []
    # standard optional fields, in Wikipedia-ish order
    order = ["born", "born_date", "date", "period", "status", "type",
             "aliases", "occupation", "known_for", "relationship",
             "partner", "parents", "location", "duration", "outcome",
             "first_mentioned", "discovered", "closed", "diagnosis",
             "medication", "ideology", "affiliation", "domain", "notes"]
    # include any keys present in the map (ordered known first, then extras)
    keys = [k for k in order if k in fb] + [k for k in fb if k not in order]
    for k in keys:
        if k in ("name", "image", "caption"):
            continue
        val = fb[k]
        if not val:
            continue
        cell = inline(val, wikilink_fn)
        rows.append(
            f'<tr><th scope="row">{esc_html(k.replace("_", " ").title())}</th>'
            f'<td>{cell}</td></tr>'
        )
    caption = fb.get("caption", "")
    cap_html = f'<div class="infobox-caption">{esc_html(caption)}</div>' if caption else ""
    return (
        f'<aside class="infobox">\n'
        f'<div class="infobox-image"><img src="{esc_attr(img_url)}" alt="{esc_attr(head)} illustration"></div>\n'
        f'<div class="infobox-caption">Illustration — not a photograph</div>\n'
        f'<table>\n<tbody>\n'
        f'<tr><th class="infobox-head" colspan="2">{esc_html(head)}</th></tr>\n'
        + "".join(rows)
        + f'{cap_html}</tbody></table>\n</aside>'
    )


def collect_pages():
    pages = []
    for p in sorted((ROOT / "wiki").rglob("*.md")):
        if any(part.startswith(".") for part in p.parts):
            continue
        pages.append(p)
    return pages


def extract_toc(md: str) -> list[tuple[int, str, str]]:
    toc = []
    for line in md.splitlines():
        m = re.match(r"^(#{2,3})\s+(.*)$", line)
        if m:
            toc.append((len(m.group(1)), re.sub(r"[*_`]", "", m.group(2)).strip(), slug(m.group(2))))
    return toc


# --------------------------------------------------------------------------
# agent feed (compact reimplementation of publish-agent outputs)
# --------------------------------------------------------------------------
def write_corpus(files: list[Path], out: Path, title: str, note: str = "") -> dict:
    today = datetime.date.today().isoformat()
    parts = [f"# {title}", "", f"Exported: {today}",
             f"Source: https://github.com/caakehorn/wiki-brain", f"Git SHA: {git_sha()}", "",
             "Compiled wiki pages only (not raw/ sources). Each section is one page.", ""]
    if note:
        parts += [note, ""]
    parts += ["## Table of contents", ""]
    for f in files:
        parts.append(f"- {f.relative_to(ROOT).as_posix()}")
    parts.append("\n---\n")
    for f in files:
        rel = f.relative_to(ROOT).as_posix()
        try:
            body = f.read_text(encoding="utf-8", errors="replace")
        except Exception as e:
            body = f"[unreadable: {e}]"
        parts.append(f"\n<!-- ===== {rel} ===== -->\n\n# FILE: {rel}\n\n{body.strip()}\n")
    text = "\n".join(parts)
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(text, encoding="utf-8")
    return {"path": out.name, "pages": len(files), "chars": len(text),
            "approx_tokens": estimate_tokens(text)}


def build_agent_feed(pages: list[Path], out: Path, base_url: str) -> dict:
    agent = out / "agent"
    agent.mkdir(parents=True, exist_ok=True)
    by_domain: dict[str, list[Path]] = {d: [] for d in DOMAINS}
    critical: list[Path] = []
    records = []
    for p in pages:
        text = p.read_text(encoding="utf-8", errors="replace")
        meta, _ = parse_frontmatter(text)
        rel = p.relative_to(ROOT).as_posix()
        domain = meta.get("domain") or (p.relative_to(ROOT / "wiki").parts[0]
                                        if p.is_relative_to(ROOT / "wiki") else "unknown")
        title = meta.get("title") or first_heading(text) or p.stem
        rec = {
            "path": rel,
            "url": f"{base_url}/{rel}",
            "github_raw": f"https://raw.githubusercontent.com/caakehorn/wiki-brain/main/{rel}",
            "domain": domain, "title": title,
            "page_type": meta.get("page_type", ""), "status": meta.get("status", ""),
            "importance": meta.get("importance", ""), "knowledge": meta.get("knowledge", ""),
            "date_modified": meta.get("date_modified", ""),
            "bytes": p.stat().st_size, "approx_tokens": estimate_tokens(text),
        }
        records.append(rec)
        if domain in by_domain:
            by_domain[domain].append(p)
        if meta.get("importance") in ("critical", "high"):
            critical.append(p)

    root_index = ROOT / "index.md"
    corpus_files = ([root_index] if root_index.exists() else []) + pages
    full = write_corpus(corpus_files, agent / "corpus.md", "Personal Wiki — full compiled corpus",
                        note="Prefer domain corpora if this exceeds your context window.")
    domain_stats = {}
    for d, files in by_domain.items():
        if not files:
            continue
        st = write_corpus(files, agent / "domains" / f"{d}.md", f"Personal Wiki — domain: {d}")
        domain_stats[d] = {**st, "url": f"{base_url}/agent/domains/{d}.md", "pages": len(files)}
    crit_stats = None
    if critical:
        critical_sorted = sorted(set(critical), key=lambda p: (
            0 if parse_frontmatter(p.read_text(encoding="utf-8", errors="replace"))[0].get("importance") == "critical" else 1,
            str(p)))
        crit_stats = write_corpus(critical_sorted, agent / "critical.md",
                                  "Personal Wiki — critical & high-importance pages",
                                  note="Spine for quick agent context.")
    sha = git_sha()
    generated = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    manifest = {
        "name": "wiki-brain", "generated_at": generated, "git_sha": sha,
        "github": "https://github.com/caakehorn/wiki-brain", "base_url": base_url,
        "entrypoints": {
            "llms_txt": f"{base_url}/llms.txt", "manifest": f"{base_url}/agent/manifest.json",
            "full_corpus": f"{base_url}/agent/corpus.md", "critical": f"{base_url}/agent/critical.md",
            "wiki_tree": f"{base_url}/wiki/",
            "github_raw_base": "https://raw.githubusercontent.com/caakehorn/wiki-brain/main/wiki/",
        },
        "stats": {"pages": len(pages), "full_corpus_approx_tokens": full["approx_tokens"],
                  "full_corpus_chars": full["chars"]},
        "domains": domain_stats, "critical_corpus": crit_stats, "pages": records,
    }
    (agent / "manifest.json").write_text(json.dumps(manifest, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")

    llms = [f"# wiki-brain", "",
            f"> Personal second-brain wiki. Compiled Markdown, updated from GitHub main ({sha[:7]}).",
            f"> Generated {generated}. Prefer these agent URLs over scraping the human site.", "",
            "## Start here", "",
            f"- [Agent manifest (JSON)]({base_url}/agent/manifest.json): machine index of every page",
            f"- [Critical spine]({base_url}/agent/critical.md): importance critical/high pages",
            f"- [Full corpus]({base_url}/agent/corpus.md): entire compiled wiki (~{full['approx_tokens']:,} tokens)",
            f"- [Master index]({base_url}/index.md): human navigation", "",
            "## Domain corpora", ""]
    for d in DOMAINS:
        if d not in domain_stats:
            continue
        st = domain_stats[d]
        llms.append(f"- [{d}]({base_url}/agent/domains/{d}.md): {st['pages']} pages, ~{st['approx_tokens']:,} tokens")
    llms += ["", "## Selective page fetch", "",
             f"- Pages base: `{base_url}/wiki/{{path}}.md`",
             f"- GitHub raw: `https://raw.githubusercontent.com/caakehorn/wiki-brain/main/wiki/{{path}}.md`", "",
             "## Notes for agents", "",
             "- This feed is the **compiled** wiki (`wiki/`), not the immutable source archive (`raw/`).",
             "- Reason from these pages first. Treat `CONTRADICTION` / `REVISED` blocks as first-class.",
             "- Check `git_sha` in the manifest for freshness.", ""]
    (out / "llms.txt").write_text("\n".join(llms), encoding="utf-8")
    return {"full_tokens": full["approx_tokens"], "domains": {k: v["approx_tokens"] for k, v in domain_stats.items()}, "sha": sha}


# --------------------------------------------------------------------------
# main build
# --------------------------------------------------------------------------
def build(out: Path, base_url: str) -> dict:
    if out.exists():
        shutil.rmtree(out)
    out.mkdir(parents=True)

    pages = collect_pages()
    known = build_known(out)
    # register auto-generated directory index pages (.html) so wikilinks to
    # [[dir/]] and [[dir/index]] resolve during page render
    for p in pages:
        parts = p.relative_to(ROOT).with_suffix("").parts[:-1]
        for d in range(1, len(parts)):
            known.add("/".join(parts[: d + 1]) + "/index.html")
    for d in DOMAINS:
        known.add(f"{d}/index.html")
    title_map = {}
    for p in pages:
        text = p.read_text(encoding="utf-8", errors="replace")
        meta, _ = parse_frontmatter(text)
        rel = p.relative_to(ROOT).with_suffix(".html").as_posix()
        title_map[rel] = meta.get("title") or first_heading(text) or p.stem
    # titles for dir indexes
    for k in list(known):
        if k.endswith("/index.html"):
            title_map.setdefault(k, k.split("/")[-2])
    # available illustration assets
    known_imgs = {f"assets/img/{f.name}" for f in (ROOT / "assets" / "img").glob("*.svg")}
    # sibling pages grouped by domain (for the navbox footer)
    siblings: dict[str, list[tuple[str, str]]] = {d: [] for d in DOMAINS}
    for p in pages:
        meta, _ = parse_frontmatter(p.read_text(encoding="utf-8", errors="replace"))
        d = meta.get("domain") or (p.relative_to(ROOT / "wiki").parts[0]
                                   if p.is_relative_to(ROOT / "wiki") else "")
        if d not in siblings:
            siblings[d] = []
        rel_html = p.relative_to(ROOT).with_suffix(".html").as_posix()
        siblings[d].append((rel_html, title_map.get(rel_html, p.stem)))

    search_records = []
    # render each wiki page to HTML
    for p in pages:
        text = p.read_text(encoding="utf-8", errors="replace")
        meta, body = parse_frontmatter(text)
        page_rel = p.relative_to(ROOT).with_suffix(".html").as_posix()
        wikilink_fn = make_wikilink(known, page_rel, title_map)
        body_html = md_to_html(body, page_rel, wikilink_fn)
        toc = extract_toc(body)
        title = title_map.get(page_rel, p.stem)
        domain = meta.get("domain") or (p.relative_to(ROOT / "wiki").parts[0]
                                        if p.is_relative_to(ROOT / "wiki") else "")
        img_url = image_for(page_rel, meta, known_imgs)
        infobox_html = build_infobox(meta, page_rel, img_url, wikilink_fn)
        navbox_html = build_navbox(domain, page_rel, siblings, title_map)
        # every article gets a picture; if an infobox already shows the image,
        # suppress the separate figure to avoid duplication
        article_img = "" if infobox_html else (
            f'<img src="{esc_attr(img_url)}" alt="{esc_attr(title)} illustration">'
        )
        html_page = render_page(meta, body_html, page_rel, title, toc, known, out, base_url,
                                navbox_html=navbox_html, infobox_html=infobox_html,
                                img_url=img_url, article_img=article_img)
        dst = out / page_rel
        dst.parent.mkdir(parents=True, exist_ok=True)
        dst.write_text(html_page, encoding="utf-8")
        # also keep raw .md for direct agent fetch
        shutil.copy2(p, out / p.relative_to(ROOT).as_posix())
        domain = meta.get("domain") or (p.relative_to(ROOT / "wiki").parts[0]
                                        if p.is_relative_to(ROOT / "wiki") else "unknown")
        snippet = re.sub(r"[#>*`\-|]", " ", body)
        snippet = re.sub(r"\s+", " ", snippet).strip()[:240]
        search_records.append({
            "title": title, "domain": domain,
            "url": relative_url("index.html", page_rel), "snippet": snippet,
        })

    # auto-generated directory index pages (browsable folders for every subdir)
    dirs: dict[str, list[tuple[str, str, str]]] = {}
    for p in pages:
        rel = p.relative_to(ROOT)
        parts = rel.with_suffix("").parts[:-1]  # drop filename
        if len(parts) <= 1:
            continue
        for d in range(1, len(parts)):
            dkey = "/".join(parts[: d + 1])
            dname = parts[d]
            if dkey not in dirs:
                dirs[dkey] = []
        child = "/".join(parts)
        title = title_map.get(rel.with_suffix(".html").as_posix(), rel.stem)
        durl = rel.with_suffix(".html").as_posix()
        dirs[child].append((rel.stem, title, durl))
    # also top-level domain dirs
    for d in DOMAINS:
        dirs.setdefault(d, [])
    for dkey, entries in dirs.items():
        # skip if a real index.md exists (already rendered)
        idx_html = dkey + "/index.html"
        if idx_html in known or idx_html == "index.html":
            continue
        parent = dkey.rsplit("/", 1)[0] if "/" in dkey else ""
        home_url = relative_url(idx_html, "index.html")
        crumb = ('<div class="crumbs"><a href="' + home_url + '">Wiki</a> &rsaquo; '
                 '<span>' + esc_html(dkey) + "</span></div>")
        rows = "".join(
            f'<li><a href="{relative_url(idx_html, e[2])}">{esc_html(e[1])}</a></li>'
            for e in sorted(entries)
        )
        title = dkey.split("/")[-1]
        dp = f"""<!DOCTYPE html><html lang="en"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{esc_html(title)} — wiki-brain</title>
<link rel="stylesheet" href="{relative_url(idx_html, 'assets/style.css')}"></head>
<body><header class="site"><div class="brand">wiki-brain<small>compiled second brain</small></div>
<input id="q" type="search" placeholder="Search the wiki…" autocomplete="off"></header>
<div class="layout">{render_sidebar(idx_html)}<main class="content">
{crumb}<h1>{esc_html(title)}</h1>
<p class="cardsmall">{len(entries)} page(s) in this section.</p>
<ul class="dirlist">{rows}</ul>
<div class="meta-note">Auto-generated directory index.</div>
</main></div>
<div id="search-results" style="max-width:1200px;margin:0 auto;padding:0 2rem 3rem"></div>
<script src="{relative_url(idx_html, 'assets/app.js')}"></script></body></html>"""
        (out / idx_html).parent.mkdir(parents=True, exist_ok=True)
        (out / idx_html).write_text(dp, encoding="utf-8")

    # root index.html from index.md
    root_index = ROOT / "index.md"
    if root_index.exists():
        shutil.copy2(root_index, out / "index.md")
        meta, body = parse_frontmatter(root_index.read_text(encoding="utf-8", errors="replace"))
        wikilink_fn = make_wikilink(known, "index.html", title_map)
        body_html = md_to_html(body, "index.html", wikilink_fn)
    else:
        body_html = ""
    cards = "".join(
        f'<div class="card"><h3><a href="wiki/{d}/index.html">{esc_html(DOMAIN_TITLES.get(d, d))}</a></h3>'
        f'<div class="cardsmall">domain</div></div>' for d in DOMAINS
    )
    home = f"""<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>wiki-brain</title><link rel="stylesheet" href="assets/style.css"></head>
<body>
<header class="site"><div class="brand">wiki-brain<small>compiled second brain</small></div>
<input id="q" type="search" placeholder="Search the wiki…" autocomplete="off"></header>
<div class="layout"><nav class="sidebar"></nav>
<main class="content">
<h1>Personal Wiki</h1>
{body_html}
<h2 style="border:none">Browse by domain</h2>
<div class="domains">{cards}</div>
<div class="meta-note">Agents: start at <a href="llms.txt">llms.txt</a> or
<a href="agent/manifest.json">agent/manifest.json</a>.</div>
</main></div>
<div id="search-results" style="max-width:1200px;margin:0 auto;padding:0 2rem 3rem"></div>
<script src="assets/app.js"></script></body></html>"""
    (out / "index.html").write_text(home, encoding="utf-8")

    # assets
    (out / "assets").mkdir(exist_ok=True)
    (out / "assets" / "style.css").write_text(CSS, encoding="utf-8")
    (out / "assets" / "app.js").write_text(JS, encoding="utf-8")
    # illustration images (committed under assets/img/) -> site/assets/img/
    src_img = ROOT / "assets" / "img"
    if src_img.is_dir():
        dst_img = out / "assets" / "img"
        dst_img.mkdir(parents=True, exist_ok=True)
        for svg in src_img.glob("*.svg"):
            shutil.copy2(svg, dst_img / svg.name)

    # search.json
    (out / "search.json").write_text(json.dumps(search_records, ensure_ascii=False), encoding="utf-8")

    # agent feed
    feed = build_agent_feed(pages, out, base_url)

    # AGENT_ACCESS.md copy
    src_access = ROOT / "AGENT_ACCESS.md"
    if src_access.exists():
        shutil.copy2(src_access, out / "AGENT_ACCESS.md")

    # .nojekyll + root README landing
    (out / ".nojekyll").write_text("", encoding="utf-8")

    return {"pages": len(pages), "out": str(out), "full_tokens": feed["full_tokens"],
            "domains": feed["domains"], "sha": feed["sha"], "base_url": base_url}


def main(argv: list[str]) -> int:
    ap = argparse.ArgumentParser(description=__doc__)
    ap.add_argument("--out", type=Path, default=DEFAULT_OUT)
    ap.add_argument("--base-url", default=os.environ.get("AGENT_BASE_URL", DEFAULT_BASE))
    args = ap.parse_args(argv)
    summary = build(args.out.resolve(), args.base_url.rstrip("/"))
    print("build-site: built static wiki")
    print(f"  out:      {summary['out']}")
    print(f"  pages:    {summary['pages']}")
    print(f"  corpus:   ~{summary['full_tokens']:,} tokens")
    print(f"  git_sha:  {summary['sha'][:12]}")
    print(f"  base_url: {summary['base_url']}")
    for d, tok in summary["domains"].items():
        print(f"    {d:12} ~{tok:,} tokens")
    print(f"\nEntrypoint: {summary['base_url']}/  (or open {summary['out']}/index.html)")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
