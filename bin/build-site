#!/usr/bin/env python3
"""build-site — render the wiki/ Markdown tree into a clean static site.

Produces BOTH:
  * a human/agent-readable HTML wiki (Wikipedia-style reader) with search,
    wikilink resolution, frontmatter badges, tables, blockquotes
  * the LLM/agent feed (llms.txt, agent/manifest.json, agent/corpus.md,
    agent/domains/<d>.md, agent/critical.md)

Zero third-party dependencies (Python stdlib only). Replaces the old Jekyll
setup entirely; the deployed site uses .nojekyll.

Usage:
  bin/build-site                 # -> site/  (relative to repo root)
  bin/build-site --out /tmp/x
  bin/build-site --base-url https://caakehorn.github.io/wiki-brain
"""
from __future__ import annotations

import argparse
import datetime
import html
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
DEFAULT_OUT = ROOT / "site"
DEFAULT_BASE = "https://caakehorn.github.io/wiki-brain"

DOMAINS = [
    "self", "timeline", "people", "mind", "work",
    "interests", "health", "places", "legal",
]
DOMAIN_TITLES = {
    "self": "Self", "timeline": "Timeline", "people": "People",
    "mind": "Mind", "work": "Work", "interests": "Interests",
    "health": "Health", "places": "Places", "legal": "Legal",
}

FM_RE = re.compile(r"^---\s*\n(.*?)\n---\s*\n", re.DOTALL)


# --------------------------------------------------------------------------
# frontmatter
# --------------------------------------------------------------------------
def parse_frontmatter(text: str) -> tuple[dict, str]:
    m = FM_RE.match(text)
    if not m:
        return {}, text
    meta = {}
    for line in m.group(1).splitlines():
        if ":" not in line or line.startswith(" ") or line.startswith("-"):
            continue
        key, _, val = line.partition(":")
        key = key.strip()
        val = val.strip().strip("\"'")
        if key in ("domain", "page_type", "status", "title", "importance",
                   "knowledge", "date_modified", "date_created", "image"):
            meta[key] = val
        # structured blocks (infobox: can be multi-line indented yaml)
    # capture a yaml 'infobox:' mapping (indented sub-keys) as a dict
    imb = re.search(r"\ninfobox:\s*\n((?:[ \t]+[^:\n]+:[^\n]*\n?)+)", m.group(1))
    if imb:
        fb = {}
        for ln in imb.group(1).splitlines():
            if ":" not in ln:
                continue
            k, _, v = ln.strip().partition(":")
            fb[k.strip()] = v.strip().strip("'\"")
        meta["infobox"] = fb
    return meta, text[m.end():]


def estimate_tokens(text: str) -> int:
    return max(1, len(text) // 4)


def git_sha() -> str:
    try:
        return subprocess.check_output(
            ["git", "rev-parse", "HEAD"], cwd=ROOT, text=True
        ).strip()
    except Exception:
        return "unknown"


def first_heading(text: str) -> str:
    for line in text.splitlines():
        if line.startswith("# "):
            return line[2:].strip()
    return ""


def slug(s: str) -> str:
    s = re.sub(r"[^\w\s-]", "", s.lower())
    s = re.sub(r"[\s_-]+", "-", s).strip("-")
    return s or "section"


def esc_html(s: str) -> str:
    return html.escape(s, quote=False)


def esc_attr(s: str) -> str:
    return html.escape(s, quote=True)


# --------------------------------------------------------------------------
# wikilink resolution
# --------------------------------------------------------------------------
def build_known(out_root: Path) -> set[str]:
    """html rel paths we will actually emit, e.g. wiki/people/annie.html"""
    known = set()
    for p in (ROOT / "wiki").rglob("*.md"):
        if any(part.startswith(".") for part in p.parts):
            continue
        rel = p.relative_to(ROOT).with_suffix(".html").as_posix()
        known.add(rel)
    return known


def relative_url(src_html_rel: str, dst_html_rel: str) -> str:
    src = Path(src_html_rel)
    dst = Path(dst_html_rel)
    rel = os.path.relpath(dst, src.parent)
    return rel.replace(os.sep, "/")


def make_wikilink(known: set[str], page_rel: str, title_map: dict[str, str]):
    def fn(raw: str) -> str:
        if "|" in raw:
            path, label = raw.split("|", 1)
            path = path.strip()
            label = label.strip()
        else:
            path, label = raw.strip(), ""
        # strip a stray .md extension if present
        cleaned = path[:-3] if path.endswith(".md") else path
        # explicit root index
        if cleaned in ("index", "wiki/index"):
            target = "index.html"
            cleaned = "index"
        else:
            # resolve target rel path (rooted at site/)
            if cleaned.startswith("wiki/"):
                cand = cleaned
            else:
                cand = cleaned
            if cleaned.endswith("/"):
                target = cand.rstrip("/") + "/index.html"
            else:
                target = cand.rstrip("/") + ".html"
            # fallback chain: basename match, or directory index
            if target not in known:
                if not cleaned.startswith("wiki/"):
                    alt = str(Path(page_rel).parent / (cleaned.rstrip("/") + ".html"))
                    if alt in known:
                        target = alt
                if target not in known and cleaned.rstrip("/").split("/")[-1] == "index":
                    root_alt = "index.html"
                    if root_alt in known:
                        target = root_alt
                if target not in known:
                    matches = [k for k in known if k.endswith("/" + cleaned.rstrip("/") + ".html")]
                    if len(matches) == 1:
                        target = matches[0]
                if target not in known and not cleaned.endswith("/"):
                    idx = cleaned.rstrip("/") + "/index.html"
                    if idx in known:
                        target = idx
        exists = target in known
        url = relative_url(page_rel, target)
        if not label:
            label = title_map.get(target, cleaned.rstrip("/").split("/")[-1]) if exists \
                else cleaned.rstrip("/").split("/")[-1]
        cls = "" if exists else ' class="wikilink-missing"'
        title_attr = "" if exists else ' title="page not found"'
        return f'<a href="{esc_attr(url)}"{cls}{title_attr}>{esc_html(label)}</a>'
    return fn


# --------------------------------------------------------------------------
# inline markdown
# --------------------------------------------------------------------------
def inline(text: str, wikilink_fn) -> str:
    codes: list[str] = []

    def stash(m):
        codes.append(m.group(1))
        return f"\x00{len(codes) - 1}\x00"

    text = re.sub(r"`([^`]+)`", stash, text)
    text = re.sub(r"\[\[([^\]]+)\]\]", lambda m: wikilink_fn(m.group(1)), text)
    text = re.sub(
        r"\[([^\]]+)\]\(([^)]+)\)",
        lambda m: f'<a href="{esc_attr(m.group(2))}">{inline_text(m.group(1), wikilink_fn)}</a>',
        text,
    )
    text = re.sub(r"\*\*([^*]+)\*\*", r"<strong>\1</strong>", text)
    text = re.sub(r"(?<!\*)\*([^*]+)\*(?!\*)", r"<em>\1</em>", text)
    text = re.sub(
        r"\x00(\d+)\x00",
        lambda m: f"<code>{esc_html(codes[int(m.group(1))])}</code>",
        text,
    )
    return text


def inline_text(text: str, wikilink_fn) -> str:
    # same as inline but without nested link capture (avoids double-a)
    codes: list[str] = []

    def stash(m):
        codes.append(m.group(1))
        return f"\x00{len(codes) - 1}\x00"

    text = re.sub(r"`([^`]+)`", stash, text)
    text = re.sub(r"\[\[([^\]]+)\]\]", lambda m: wikilink_fn(m.group(1)), text)
    text = re.sub(r"\*\*([^*]+)\*\*", r"<strong>\1</strong>", text)
    text = re.sub(r"(?<!\*)\*([^*]+)\*(?!\*)", r"<em>\1</em>", text)
    text = re.sub(
        r"\x00(\d+)\x00",
        lambda m: f"<code>{esc_html(codes[int(m.group(1))])}</code>",
        text,
    )
    return text


# --------------------------------------------------------------------------
# block markdown -> html
# --------------------------------------------------------------------------
TABLE_SEP_RE = re.compile(r"^\s*\|?[\s:+-]+\|?[\s:+-]*$")


def split_row(line: str) -> list[str]:
    line = line.strip()
    if line.startswith("|"):
        line = line[1:]
    if line.endswith("|"):
        line = line[:-1]
    return [c.strip() for c in line.split("|")]


def is_block_start(line: str, nxt: str) -> bool:
    if re.match(r"^#{1,6}\s+", line):
        return True
    if line.strip().startswith("```"):
        return True
    if re.match(r"^-{3,}$", line.strip()) or re.match(r"^\*{3,}$", line.strip()):
        return True
    if line.lstrip().startswith(">"):
        return True
    if re.match(r"^\s*[-*]\s+", line) or re.match(r"^\s*\d+\.\s+", line):
        return True
    if "|" in line and "-" in nxt and TABLE_SEP_RE.match(nxt):
        return True
    return False


def md_to_html(md: str, page_rel: str, wikilink_fn) -> str:
    lines = md.split("\n")
    out: list[str] = []
    i = 0
    while i < len(lines):
        line = lines[i]
        if line.strip().startswith("```"):
            i += 1
            buf = []
            while i < len(lines) and not lines[i].strip().startswith("```"):
                buf.append(lines[i])
                i += 1
            i += 1
            out.append(
                '<pre class="code"><code>'
                + "\n".join(esc_html(l) for l in buf)
                + "</code></pre>"
            )
            continue
        if not line.strip():
            i += 1
            continue
        if re.match(r"^-{3,}$", line.strip()) or re.match(r"^\*{3,}$", line.strip()):
            out.append("<hr>")
            i += 1
            continue
        m = re.match(r"^(#{1,6})\s+(.*)$", line)
        if m:
            level = len(m.group(1))
            txt = inline(m.group(2), wikilink_fn)
            out.append(f'<h{level} id="{slug(m.group(2))}">{txt}</h{level}>')
            i += 1
            continue
        if "|" in line and i + 1 < len(lines) and TABLE_SEP_RE.match(lines[i + 1]):
            header = split_row(line)
            i += 2
            rows = []
            while i < len(lines) and lines[i].strip() and "|" in lines[i]:
                rows.append(split_row(lines[i]))
                i += 1
            th = "".join(f"<th>{inline(c, wikilink_fn)}</th>" for c in header)
            body = ""
            for r in rows:
                tds = "".join(f"<td>{inline(c, wikilink_fn)}</td>" for c in r)
                body += f"<tr>{tds}</tr>"
            out.append(f'<table class="wiki-table"><thead><tr>{th}</tr></thead>'
                       f"<tbody>{body}</tbody></table>")
            continue
        if line.lstrip().startswith(">"):
            buf = []
            while i < len(lines) and lines[i].lstrip().startswith(">"):
                buf.append(lines[i].lstrip()[1:].strip())
                i += 1
            joined = "\n".join(buf)
            cls = "blockquote"
            if buf and buf[0].startswith("**CONTRADICTION"):
                cls = "bq-contradiction"
            elif buf and buf[0].startswith("**REVISED"):
                cls = "bq-revised"
            # render blockquote inner as paragraph(s)
            inner = "".join(
                f"<p>{inline(b, wikilink_fn)}</p>" for b in joined.split("\n") if b.strip()
            )
            out.append(f'<blockquote class="{cls}">{inner}</blockquote>')
            continue
        if re.match(r"^\s*[-*]\s+", line) or re.match(r"^\s*\d+\.\s+", line):
            ordered = bool(re.match(r"^\s*\d+\.\s+", line))
            raw_items: list[list[str]] = []
            cur: list[str] | None = None
            while i < len(lines):
                ln = lines[i]
                m = re.match(r"^\s*(?:[-*]|\d+\.)\s+", ln)
                cont = re.match(r"^\s{2,}\S", ln)
                if m:
                    cur = [re.sub(r"^\s*(?:[-*]|\d+\.)\s+", "", ln)]
                    raw_items.append(cur)
                    i += 1
                elif cont and cur is not None:
                    cur.append(ln.strip())
                    i += 1
                elif ln.strip() == "":
                    if i + 1 < len(lines) and (
                        re.match(r"^\s*(?:[-*]|\d+\.)\s+", lines[i + 1])
                        or re.match(r"^\s{2,}\S", lines[i + 1])
                    ):
                        i += 1
                    else:
                        break
                else:
                    break
            tag = "ol" if ordered else "ul"
            lis = "".join(
                f"<li>{inline(' '.join(x.strip() for x in ls), wikilink_fn)}</li>"
                for ls in raw_items
            )
            out.append(f"<{tag}>{lis}</{tag}>")
            continue
        # paragraph
        buf = [line]
        i += 1
        while (
            i < len(lines)
            and lines[i].strip()
            and not is_block_start(lines[i], lines[i + 1] if i + 1 < len(lines) else "")
        ):
            buf.append(lines[i])
            i += 1
        para = " ".join(x.strip() for x in buf)
        out.append(f"<p>{inline(para, wikilink_fn)}</p>")
    return "\n".join(out)


# --------------------------------------------------------------------------
# layout
# --------------------------------------------------------------------------
