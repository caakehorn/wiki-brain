#!/usr/bin/env python3
"""export-corpus — bundle the wiki into a single file for LLM ingestion.

Usage:
  export-corpus                 export compiled wiki/ pages (the default)
  export-corpus --domain mind   export one domain only
  export-corpus --raw           also include raw/ source archive (big)
  export-corpus --inbox         also include un-ingested inbox items
  export-corpus --out FILE      custom output path

Output goes to exports/corpus_YYYY-MM-DD[_domain].md with a table of
contents, one section per page, and a token estimate at the end.
"""
import datetime
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
TEXT_EXT = {".md", ".txt", ".csv", ".json", ".html", ".rtf"}


def gather(dirs, domain=None):
    files = []
    for d in dirs:
        base = ROOT / d
        if domain and d == "wiki":
            base = base / domain
        if not base.exists():
            continue
        for p in sorted(base.rglob("*")):
            if p.is_file() and p.suffix.lower() in TEXT_EXT and not p.name.startswith("."):
                files.append(p)
    return files


def main(argv):
    domain = None
    dirs = ["wiki"]
    out = None
    if "-h" in argv or "--help" in argv:
        print(__doc__)
        return
    if "--domain" in argv:
        domain = argv[argv.index("--domain") + 1]
    if "--raw" in argv:
        dirs.append("raw")
    if "--inbox" in argv:
        dirs.append("inbox")
    if "--out" in argv:
        out = Path(argv[argv.index("--out") + 1]).resolve()

    files = []
    root_index = ROOT / "index.md"
    if root_index.exists() and not domain:
        files.append(root_index)
    files += gather(dirs, domain)

    if not files:
        print("nothing to export yet — the wiki is empty")
        return

    today = datetime.date.today().isoformat()
    name = f"corpus_{today}" + (f"_{domain}" if domain else "") + ".md"
    out = out or ROOT / "exports" / name
    out.parent.mkdir(exist_ok=True)

    parts = [
        f"# Personal Wiki Corpus — exported {today}",
        "",
        "This is the complete text corpus of a personal wiki: biographical history,",
        "psychological/ideological profile, relationships, and life records of one person.",
        "Each section below is one page, headed by its path.",
        "",
        "## Table of contents",
        "",
    ]
    for f in files:
        parts.append(f"- {f.relative_to(ROOT)}")
    parts.append("\n---\n")

    for f in files:
        rel = f.relative_to(ROOT)
        try:
            body = f.read_text(encoding="utf-8", errors="replace")
        except Exception as e:
            body = f"[unreadable: {e}]"
        parts.append(f"\n<!-- ===== {rel} ===== -->\n\n# FILE: {rel}\n\n{body.strip()}\n")

    text = "\n".join(parts)
    out.write_text(text, encoding="utf-8")
    tokens = len(text) // 4
    shown = out.relative_to(ROOT) if str(out).startswith(str(ROOT)) else out
    print(f"exported {len(files)} pages -> {shown}")
    print(f"  {len(text):,} chars, ~{tokens:,} tokens")
    if tokens > 180_000:
        print("  note: likely exceeds a single 200k context window — consider --domain exports")


if __name__ == "__main__":
    main(sys.argv[1:])
